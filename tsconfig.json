{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext"],
		"allowJs": false,
		"strict": true,
		"esModuleInterop": false,
		"outDir": "build",
		"rootDir": "src",
		"typeRoots": ["node_modules"],
		"skipLibCheck": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "build"]
}
